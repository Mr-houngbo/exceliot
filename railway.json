{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "api": {
      "source": "apps/api",
      "dockerfilePath": "Dockerfile",
      "healthcheckPath": "/health"
    },
    "worker": {
      "source": "apps/workers",
      "dockerfilePath": "Dockerfile",
      "startCommand": "celery -A celery_app worker --loglevel=info"
    },
    "beat": {
      "source": "apps/workers",
      "dockerfilePath": "Dockerfile",
      "startCommand": "celery -A celery_app beat --loglevel=info"
    }
  }
}
